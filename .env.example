# Harbor Environment Example (SLO + Resume Launch)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Resume SSO Launch
RESUME_APP_URL=http://localhost:3001
RESUME_SSO_SIGNING_KEY=CHANGE_ME
RESUME_SSO_VERIFY_SECRET=CHANGE_ME
RESUME_SSO_LINK_SECRET=CHANGE_ME
RESUME_SSO_TOKEN_TTL_SECONDS=90
RESUME_USE_UNIFIED_ORIGIN=false

# Resume Launch SLO Monitor Thresholds
RESUME_ALERT_WINDOW_MINUTES=15
RESUME_ALERT_MIN_SUCCESS_RATE=0.995
RESUME_ALERT_MAX_P95_MS=1800
